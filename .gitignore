figures/
images/
*.pdf
*.png
*.jpg
*.jpeg

# Ignore model weights and saved states
*.pth
*.h5
*.weights
models/__pycache__/

# Ignore specific prediction outputs
predictions/

# --- System/IDE Bloat ---
.DS_Store
.vscode/
.idea/
*.swp

# --- Sensitive Info ---
.env
auth.json
secrets.py
